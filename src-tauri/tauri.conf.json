{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Epic Quick Switch",
  "version": "0.1.0",
  "identifier": "epic-quick-switch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Bxnny24/Epic-Quick-Switch/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZBMjQyNzlEMzRBNjBFQjMKUldTekRxWTBuU2NrK3Y2QnlGMWFyaVQvMnNmRk9MTVZvdmYyZWMyV0FlVi9iOVd6TlUwTmtZbFkK"
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Epic Quick Switch",
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
